{
  "info": {
    "name": "QA Practice - Task Tracker API",
    "_postman_id": "qa-practice-collection",
    "description": "Full test collection for the Task Tracker API.\n\nSetup: Run 'Register + Login' first — it auto-saves the token for all other requests.\n\nTests tab examples are included in each request.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000/api" },
    { "key": "auth_token", "value": "" },
    { "key": "task_id", "value": "" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// --- STATUS CODE ---",
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// --- RESPONSE BODY ---",
              "pm.test('Body contains status ok', function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body.status).to.eql('ok');",
              "});",
              "",
              "// --- RESPONSE TIME ---",
              "pm.test('Response time < 500ms', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(500);",
              "});",
              "",
              "// --- HEADERS ---",
              "pm.test('Content-Type is JSON', function () {",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register - Happy Path",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"qauser{{$timestamp}}@example.com\",\n  \"password\": \"Test1234!\",\n  \"name\": \"QA Tester\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has user fields', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('id');",
                  "    pm.expect(body).to.have.property('email');",
                  "    pm.expect(body).to.have.property('name');",
                  "    pm.expect(body).to.have.property('created_at');",
                  "});",
                  "",
                  "pm.test('Password is NOT in response', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.not.have.property('password');",
                  "    pm.expect(body).to.not.have.property('password_hash');",
                  "});",
                  "",
                  "// Save email for login request",
                  "pm.collectionVariables.set('test_email', pm.response.json().email);"
                ]
              }
            }
          ]
        },
        {
          "name": "Register - Missing Fields (400)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"incomplete@example.com\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 400', function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Error message has details array', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('details');",
                  "    pm.expect(body.details).to.be.an('array');",
                  "    pm.expect(body.details.length).to.be.at.least(1);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Register - Duplicate Email (409)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{test_email}}\",\n  \"password\": \"Test1234!\",\n  \"name\": \"Duplicate\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 409 Conflict', function () {",
                  "    pm.response.to.have.status(409);",
                  "});",
                  "",
                  "pm.test('Error mentions already registered', function () {",
                  "    pm.expect(pm.response.json().error).to.include('already registered');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login - Happy Path",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{test_email}}\",\n  \"password\": \"Test1234!\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has token', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('token');",
                  "    pm.expect(body.token).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "// AUTO-SAVE TOKEN for subsequent requests",
                  "pm.collectionVariables.set('auth_token', pm.response.json().token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login - Wrong Password (401)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{test_email}}\",\n  \"password\": \"WrongPassword!\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 401', function () {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "",
                  "// SECURITY: error should NOT reveal whether email exists",
                  "pm.test('Generic error message (no info leak)', function () {",
                  "    pm.expect(pm.response.json().error).to.eql('Invalid email or password');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task - Happy Path",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/tasks",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Practice API testing\",\n  \"description\": \"Use Postman and Playwright\",\n  \"priority\": \"high\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Task has all expected fields', function () {",
                  "    const task = pm.response.json();",
                  "    pm.expect(task).to.have.all.keys(",
                  "        'id', 'title', 'description', 'status', 'priority',",
                  "        'assignee', 'created_by', 'created_at', 'updated_at'",
                  "    );",
                  "});",
                  "",
                  "pm.test('Defaults are applied correctly', function () {",
                  "    const task = pm.response.json();",
                  "    pm.expect(task.status).to.eql('todo');",
                  "});",
                  "",
                  "// Save task ID for GET/PUT/DELETE",
                  "pm.collectionVariables.set('task_id', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Task - No Auth (401)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/tasks",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Should fail\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 401 without auth', function () {",
                  "    pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Task by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/tasks/{{task_id}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Returns correct task', function () {",
                  "    const task = pm.response.json();",
                  "    pm.expect(task.id).to.eql(pm.collectionVariables.get('task_id'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Task - Not Found (404)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/tasks/does-not-exist-12345"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 404', function () {",
                  "    pm.response.to.have.status(404);",
                  "});",
                  "",
                  "pm.test('Error message is descriptive', function () {",
                  "    pm.expect(pm.response.json().error).to.include('not found');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/tasks/{{task_id}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_progress\",\n  \"priority\": \"critical\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Fields are updated', function () {",
                  "    const task = pm.response.json();",
                  "    pm.expect(task.status).to.eql('in_progress');",
                  "    pm.expect(task.priority).to.eql('critical');",
                  "});",
                  "",
                  "pm.test('Unchanged fields are preserved', function () {",
                  "    const task = pm.response.json();",
                  "    pm.expect(task.title).to.eql('Practice API testing');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "List Tasks with Filters",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/tasks?status=in_progress&per_page=5&page=1",
              "host": ["{{base_url}}"],
              "path": ["tasks"],
              "query": [
                { "key": "status", "value": "in_progress" },
                { "key": "per_page", "value": "5" },
                { "key": "page", "value": "1" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has pagination metadata', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('pagination');",
                  "    pm.expect(body.pagination).to.have.all.keys('page', 'per_page', 'total', 'total_pages');",
                  "});",
                  "",
                  "pm.test('All returned tasks match filter', function () {",
                  "    const tasks = pm.response.json().tasks;",
                  "    tasks.forEach(task => {",
                  "        pm.expect(task.status).to.eql('in_progress');",
                  "    });",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/tasks/{{task_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify Delete - Should 404",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/tasks/{{task_id}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Confirm the deleted task is actually gone",
                  "pm.test('Deleted task returns 404', function () {",
                  "    pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
